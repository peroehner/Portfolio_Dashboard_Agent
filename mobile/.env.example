# Point at your PDA API (local or Render). Must include /api/v1 suffix.
EXPO_PUBLIC_API_BASE_URL=http://localhost:5001/api/v1

# Local dev only — must match MOBILE_DEV_TOKEN in the repo root .env (when OAuth is on)
EXPO_PUBLIC_MOBILE_DEV_TOKEN=pda-local-mobile-dev

# Optional: show API host in the status bar area during development
EXPO_PUBLIC_SHOW_API_HOST=1
