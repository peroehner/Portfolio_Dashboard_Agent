# API URL: omit EXPO_PUBLIC_API_BASE_URL to auto-pick (simulator → localhost, iPhone → Render).
# Override only when needed:
#   EXPO_PUBLIC_API_BASE_URL=http://localhost:5001/api/v1
#   EXPO_PUBLIC_API_BASE_URL=https://portfolio-dashboard-agent.onrender.com/api/v1
#
# npm scripts:
#   npm run ios:local     → force localhost (simulator)
#   npm run start:render  → force Render (any device)

# Must match MOBILE_DEV_TOKEN on the API (local .env or Render dashboard)
EXPO_PUBLIC_MOBILE_DEV_TOKEN=pda-local-mobile-dev

EXPO_PUBLIC_SHOW_API_HOST=1
