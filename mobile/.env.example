# Do NOT set EXPO_PUBLIC_API_BASE_URL here — it comes from npm scripts:
#   npm run ios:local     → http://localhost:5001/api/v1 (simulator)
#   npm run start:render  → https://portfolio-dashboard-agent.onrender.com/api/v1 (iPhone)

# Must match MOBILE_DEV_TOKEN on the API (local .env or Render dashboard)
EXPO_PUBLIC_MOBILE_DEV_TOKEN=pda-local-mobile-dev

EXPO_PUBLIC_SHOW_API_HOST=1
