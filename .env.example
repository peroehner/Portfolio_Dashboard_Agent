# Server
PORT=5001
FLASK_DEBUG=0
FREE_PORT=1

# Database — Postgres (psycopg3). Local default matches docker-compose.yml.
# Start local DB with: docker compose up -d db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio
# Connection pool sizing (optional)
# DB_POOL_MIN=1
# DB_POOL_MAX=10
# Single-user fallback account used for all data until Google OAuth (Phase 2)
# is enabled, and for background jobs / scripts. Existing data is backfilled to it.
# BOOTSTRAP_USER_EMAIL=local@portfolio.local
# Throwaway database for the schema-resetting tests (never set this to your real DB)
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio_test

# Production — skip heavy ML deps (Render default)
SKIP_TRANSFORMERS=1

# Assessments: auto | rules | openai | gemini
# auto = use LLM if API key is set, else rules
ASSESSMENT_MODE=auto

# Optional — append to note synthesis prompt (your guidance for growth/catalyst extraction)
# NOTE_SYNTHESIS_GUIDANCE=Focus on segment growth rates and revenue run-rate milestones.

# Optional LLM (set one provider + key on Render dashboard)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# LLM_PROVIDER=gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash

# Assessment enrichment: fundamentals + recent news (yfinance, no key required)
# ASSESSMENT_FUNDAMENTALS=1            # set 0 to disable enrichment
# FUNDAMENTALS_PROVIDER=yfinance       # extension point for FMP/Finnhub later
# ASSESSMENT_NEWS_LIMIT=6              # max recent headlines fed to the model
# NEWS_CACHE_TTL_SECONDS=3600
# NEWS_CACHE_MAX_ENTRIES=48

# News provider: finnhub (true per-ticker) or yfinance (default).
# Leave NEWS_PROVIDER unset to auto-pick finnhub when FINNHUB_API_KEY is set,
# else yfinance. Finnhub failures fall back to yfinance automatically.
# Get a free key at https://finnhub.io/dashboard
# NEWS_PROVIDER=finnhub
# FINNHUB_API_KEY=
# FINNHUB_NEWS_DAYS=30                 # lookback window for company news

# Alerts
FIB_PROXIMITY_PCT=1.0

# Fibonacci swing levels (yfinance history lookback + in-memory cache TTL)
# FIB_LOOKBACK_PERIOD=90d
# FIB_CACHE_TTL_SECONDS=900
# FIB_CACHE_MAX_ENTRIES=64

# Memory tuning (Render free tier ~512MB)
# TARGET_REFRESH_CYCLES=12
# YFINANCE_INFO_CACHE_TTL_SECONDS=900
# YFINANCE_INFO_CACHE_MAX_ENTRIES=48
# YTD_PRICE_CACHE_TTL_SECONDS=3600
