# Server
PORT=5001
FLASK_DEBUG=0
FREE_PORT=1

# Database — Postgres (psycopg3). Local default matches docker-compose.yml.
# Start local DB with: docker compose up -d db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio
# Connection pool sizing (optional)
# DB_POOL_MIN=1
# DB_POOL_MAX=10
# Single-user fallback account used for all data until Google OAuth (Phase 2)
# is enabled, and for background jobs / scripts. Existing data is backfilled to it.
# BOOTSTRAP_USER_EMAIL=local@portfolio.local
# Throwaway database for the schema-resetting tests (never set this to your real DB)
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio_test

# Production — skip heavy ML deps (Render default)
SKIP_TRANSFORMERS=1

# Assessments: auto | rules | openai | gemini
# auto = use LLM if API key is set, else rules
ASSESSMENT_MODE=auto

# Optional LLM (set one provider + key on Render dashboard)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# LLM_PROVIDER=gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash

# Assessment technical signals (computed from price history, no key required).
# Multi-timeframe trend/momentum + adaptive Fibonacci swing fed into assessments.
# Imported technical-export snapshots still take precedence for the swing anchor.
# ASSESSMENT_TECHNICALS=1              # set 0 to disable (A/B vs prior behaviour)
# TECHNICAL_SIGNALS_PERIOD=2y         # history pulled per symbol (needs ~1y+ for 200DMA)
# TECHNICAL_SIGNALS_CACHE_TTL_SECONDS=900
# TECHNICAL_SIGNALS_CACHE_MAX_ENTRIES=64
# Failed history fetches are cached only this briefly (not the full TTL above), so
# a transient miss doesn't freeze a symbol's patterns/trends blank for 15 min:
# TECHNICAL_HISTORY_FAIL_COOLDOWN_SECONDS=120
# Cap concurrent yfinance history fetches process-wide so the pattern/Fib-map
# fan-out doesn't burst Yahoo (alongside the background sync) and trip rate limits:
# TECHNICAL_HISTORY_MAX_CONCURRENCY=3
# Adaptive swing/zig-zag pivot threshold (0 = derive from ATR volatility):
# TECHNICAL_PIVOT_PCT=0
# TECHNICAL_PIVOT_ATR_MULT=2.5        # threshold = ATR% * mult, clamped to [min,max]
# TECHNICAL_PIVOT_MIN_PCT=4
# TECHNICAL_PIVOT_MAX_PCT=18
# Tier 3: named chart-pattern detection (H&S, double top/bottom, triangles) over
# the pivot sequence. Fed to the LLM/rules as one probabilistic input + shown in
# the Inspector. Patterns are subjective with mixed reliability.
# ASSESSMENT_PATTERNS=1                # set 0 to disable pattern detection
# TECHNICAL_PATTERN_TOL_PCT=3         # how close pivots must be to count as "similar"

# Volume analytics (Phase 0+1): relative volume / OBV trend plus an approximate
# volume profile with Point of Control (POC) and Value Area. Derived from the
# SAME cached daily history (Volume was previously discarded) — no extra Yahoo
# calls. A true tick-level POC needs intraday data no free feed provides; this
# approximates it by spreading each day's volume across its High–Low range.
# VOLUME_PROFILE_LOOKBACK=252         # sessions included in the volume profile
# VOLUME_PROFILE_BINS=24              # price buckets in the profile (POC resolution)
# VOLUME_VALUE_AREA_PCT=0.70          # share of volume that defines the Value Area

# Risk agent (Phase 2): validate each detected pattern against volume before it
# can drive a recommendation — breakout RVOL, conviction at the reversal level vs
# the POC, and OBV alignment. Weak/veto patterns are flagged in the Inspector and
# the Patterns & Tech Signals tab, down-weighted for the LLM, and vetoed ones are
# not recorded as track-record bets.
# ASSESSMENT_PATTERN_VOLUME=1          # set 0 to disable volume validation entirely
# RISK_PATTERN_ACTION=downgrade        # 'downgrade' (flag + down-weight) or 'veto' (drop veto-grade patterns)
# VOLUME_BREAKOUT_RVOL=1.3            # RVOL on the break needed to call it "volume-confirmed"
# RISK_PATTERN_CONFIRM_SCORE=0.62     # validation score at/above which a confirmed pattern is "volume-confirmed"
# RISK_PATTERN_VETO_SCORE=0.40        # validation score below which a pattern is vetoed
# Staleness gating: a pattern stops being a live signal once its move has played
# out (target reached) or it is old and price has walked away from the key level.
# Such patterns are relabelled "stale", down-weighted, and kept out of the track
# record (e.g. an inverse H&S whose target was hit while price ran far past it).
# RISK_PATTERN_TARGET_DONE=1.0        # fraction of the measured move completed = "played out" (1.0 = target hit)
# RISK_PATTERN_STALE_AGE_BARS=90      # sessions since the last pivot before a pattern can age out
# RISK_PATTERN_STALE_MOVE_PCT=12      # % price must have left the key level for an aged pattern to be stale

# Confluence agent (Phase 3): fuses the independent technical lenses (trend,
# structure, momentum, the Risk-validated pattern, and volume/OBV) into ONE bias
# (Bullish … Bearish) with an explicit list of agreeing vs conflicting signals.
# This fused bias drives the Tech Stance and is fed to the LLM so a recommendation
# can lean on consensus instead of a single signal. Weights scale how much each
# lens counts before its own magnitude scaling.
# CONFLUENCE_WEIGHT_TREND=1.0         # moving-average stack / cross / slope
# CONFLUENCE_WEIGHT_STRUCTURE=0.8     # zig-zag higher-highs / lower-lows read
# CONFLUENCE_WEIGHT_MOMENTUM=0.5      # MACD histogram / RSI regime
# CONFLUENCE_WEIGHT_PATTERN=1.0       # named chart pattern (already volume-validated)
# CONFLUENCE_WEIGHT_VOLUME=0.6        # RVOL regime + OBV accumulation/distribution
# CONFLUENCE_LEAN_SCORE=0.15          # |score| at/above which the bias leans bull/bear (else Mixed)
# CONFLUENCE_STRONG_SCORE=0.45        # |score| at/above which the bias is a full Bullish/Bearish

# Tier 4: self-scoring track record. Each assessment captures its recommendation
# (and detected patterns) as a forward-looking bet; once the horizon elapses the
# move is scored win/loss/neutral and surfaced read-only in the Summary view.
# Measurement only — future signals are not auto-weighted yet.
# TRACK_RECORD=1                       # set 0 to stop capturing/scoring signals
# TRACK_RECORD_HORIZON_DAYS=21        # days after capture before a signal is scored
# TRACK_RECORD_BAND_PCT=2.0           # dead-band; moves smaller than this are "neutral"

# Assessment enrichment: fundamentals + recent news (yfinance, no key required)
# ASSESSMENT_FUNDAMENTALS=1            # set 0 to disable enrichment
# FUNDAMENTALS_PROVIDER=yfinance       # extension point for FMP/Finnhub later
# ASSESSMENT_NEWS_LIMIT=6              # max recent headlines fed to the model
# NEWS_CACHE_TTL_SECONDS=3600
# NEWS_CACHE_MAX_ENTRIES=48

# News provider: finnhub (true per-ticker) or yfinance (default).
# Leave NEWS_PROVIDER unset to auto-pick finnhub when FINNHUB_API_KEY is set,
# else yfinance. Finnhub failures fall back to yfinance automatically.
# Get a free key at https://finnhub.io/dashboard
# NEWS_PROVIDER=finnhub
# FINNHUB_API_KEY=
# FINNHUB_NEWS_DAYS=30                 # lookback window for company news

# Authentication — Google OAuth (Phase 2). OPT-IN: when CLIENT_ID/SECRET are
# unset the app runs single-user (all data under BOOTSTRAP_USER_EMAIL). When set,
# login is required and each Google account gets its own scoped portfolio.
# Create credentials at https://console.cloud.google.com/apis/credentials
# SESSION_SECRET=change-me-to-a-long-random-string   # signs the session cookie
# GOOGLE_OAUTH_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=...
# Redirect URI must match one registered in Google exactly. Defaults to
# <request-origin>/auth/callback; set explicitly behind a proxy/ngrok or on Render.
# OAUTH_REDIRECT_URI=http://localhost:5001/auth/callback
# Restrict who can sign in (comma-separated). Empty = any Google account.
# ALLOWED_EMAILS=you@gmail.com
# Set to 1 in production (HTTPS) so the session cookie is marked Secure.
# SESSION_COOKIE_SECURE=0

# Commercialization — Phase A (shared market data + deduplicated assessments)
# Market quotes are stored once per ticker in symbol_market; background sync
# fetches the union of all users' symbols and evaluates alerts per user.
# SYMBOL_MARKET_BACKFILL runs automatically on boot (app_meta guard).
# Shared fundamentals are persisted in symbol_market.fundamentals_json (news stays in-memory).
# SYMBOL_MARKET_FUNDAMENTALS=1
# SYMBOL_MARKET_FUNDAMENTALS_TTL_SECONDS=21600
# Phase A step 2+: symbol_assessment holds one base LLM assessment per symbol per UTC day (DEDUP_BASE_ASSESSMENT=1).
# Personal thresholds/notes are applied via AssessmentOverlayService after the base.
# DEDUP_BASE_ASSESSMENT=1
# Pre-warm shared base assessments once per UTC day after price sync:
# DAILY_ASSESSMENT_WORKER=1

# Commercialization — Phase B (billing / tiers)
# users.plan is one of: free, standard, pro (default free).
# Free: 10 symbols, 6 Manual AI Actions/day (note synthesis + manual assessments).
# Standard: 50 symbols, unlimited synthesis & Assess All.
# Pro: unlimited symbols, synthesis & Assess All.
# USER_PLAN_OVERRIDE=pro          # dev/staging only — test gates without Stripe
# Stripe (Phase B step 3+): STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, price IDs

# Alerts
FIB_PROXIMITY_PCT=1.0

# Fibonacci swing levels (yfinance history lookback + in-memory cache TTL)
# FIB_LOOKBACK_PERIOD=90d
# FIB_CACHE_TTL_SECONDS=900
# FIB_CACHE_MAX_ENTRIES=64

# Memory tuning (Render free tier ~512MB)
# TARGET_REFRESH_CYCLES=12
# YFINANCE_INFO_CACHE_TTL_SECONDS=900
# YFINANCE_INFO_CACHE_MAX_ENTRIES=48
# YTD_PRICE_CACHE_TTL_SECONDS=3600
#
# Failure cooldown (negative cache) for Yahoo fetches. When Yahoo blocks a
# request (e.g. "401 Invalid Crumb" from a datacenter IP), the failing symbol is
# skipped for this many seconds instead of being retried on every request and
# every 30s auto-refresh. Lower it to recover faster after a block lifts; set to
# 0 to disable and always retry (restores the old retry-storm behavior).
# YFINANCE_FAILURE_COOLDOWN_SECONDS=600
#
# PROCESS-WIDE Yahoo concurrency cap. Every Yahoo call — the engine's bulk
# price sync, the Patterns/Fib-map fan-out, fundamentals, and the Inspector —
# funnels through one shared semaphore so they can't collectively flood Yahoo
# and trip its rate limiter (which silently blanks pattern/trend columns for a
# couple of minutes). This is the hard ceiling across all subsystems; the
# per-view TECHNICAL_HISTORY_MAX_CONCURRENCY above still applies within it.
# YFINANCE_MAX_CONCURRENCY=4
# Optional minimum spacing (seconds) between Yahoo requests; 0 = no spacing.
# YFINANCE_MIN_REQUEST_INTERVAL_SECONDS=0
# Size of the SHARED, persistent worker pool used for parallel Yahoo fetches
# (Patterns view, /patterns, fundamentals bulk). Reusing fixed threads keeps
# yfinance's per-thread SQLite cache handles bounded — per-request pools used to
# leak file descriptors until the process hit its open-file limit and silently
# returned empty history. Defaults to YFINANCE_MAX_CONCURRENCY + 2.
# YFINANCE_POOL_WORKERS=6
# Log threshold for yfinance's OWN logger. Yahoo intermittently blocks datacenter
# IPs (Render) with 401 "Invalid Crumb" / "unable to access this feature"; these
# are expected and auto-recovered (session reset + cooldown + throttle), so by
# default we raise yfinance to CRITICAL to keep them out of the logs. Set to
# ERROR or WARNING to see them again while debugging.
# YFINANCE_LOG_LEVEL=CRITICAL
